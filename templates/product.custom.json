{
  "sections": {
    "previewer": {
      "type": "perkie-previewer",
      "settings": {
        "mode": "product",
        "active_style": "",
        "memorial_mode": false,
        "api_url": "https://perkie-api-production.up.railway.app"
      }
    },
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description"
        },
        "collapsible-how": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How it works",
            "icon": "camera",
            "content": "<p>Upload your pet's photo and choose your favorite style. Our AI generates a preview in seconds, then a real artist reviews every portrait before production. Most orders ship within 3-5 business days.</p>",
            "page": ""
          }
        },
        "collapsible-shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "<p>Free shipping on orders over $75. Most orders ship within 3-5 business days. 100% satisfaction guaranteed or your money back.</p>",
            "page": ""
          }
        },
        "collapsible-quality": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Quality guarantee",
            "icon": "heart",
            "content": "<p>Every portrait is personally reviewed by a real artist. If you are not completely satisfied, we will make it right or give you a full refund.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "collapsible-how",
        "collapsible-shipping",
        "collapsible-quality",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Customers also love",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "adapt",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "previewer",
    "main",
    "related-products"
  ]
}
